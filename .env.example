# DermaScan - variables de entorno

# Activa MLflow Model Registry. Si no existe, la app usa modelo_dermascan.keras local.
MLFLOW_TRACKING_URI=http://127.0.0.1:5001
MLFLOW_MODEL_NAME=dermascan-clasificador-piel
MLFLOW_MODEL_ALIAS=champion

# Fallback local cuando MLFLOW_TRACKING_URI no esta definido.
DERMASCAN_MODEL_LOCAL_PATH=modelo_dermascan.keras
DERMASCAN_UMBRAL_OPTIMO=0.70
DERMASCAN_UMBRAL_SCREENING=0.45

# Parametros operativos de abstencion por incertidumbre.
DERMASCAN_MARGEN_DUDA=0.10
DERMASCAN_UMBRAL_ABSTENCION=0.03
DERMASCAN_N_PASADAS_ABSTENCION=6
